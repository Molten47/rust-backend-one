{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            wi.id,\n            wi.book_id,\n            wi.added_at,\n            b.title,\n            b.author,\n            b.price\n        FROM wishlist_items wi\n        JOIN books b ON wi.book_id = b.id\n        WHERE wi.wishlist_id = $1\n        ORDER BY wi.added_at DESC\n        ",
