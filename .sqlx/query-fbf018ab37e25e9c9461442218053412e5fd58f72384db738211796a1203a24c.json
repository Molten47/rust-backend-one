{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            ci.id,\n            ci.book_id,\n            ci.quantity,\n            ci.price_snapshot,\n            b.title,\n            b.author,\n            b.cover_emoji,\n            b.cover_color,\n            b.cover_url,\n            b.bookstore_id,\n            bs.name AS bookstore_name\n        FROM cart_items ci\n        JOIN books b ON ci.book_id = b.id\n        JOIN bookstores bs ON b.bookstore_id = bs.id\n        WHERE ci.cart_id = $1\n        ORDER BY ci.created_at ASC  \n        ",
