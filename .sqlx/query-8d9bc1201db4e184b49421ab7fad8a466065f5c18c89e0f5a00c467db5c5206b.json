  "query": "\n        SELECT\n            oi.id,\n            oi.book_id,\n            oi.quantity,\n            oi.unit_price,\n            b.title,\n            b.author,\n            b.cover_emoji,\n            b.cover_color\n        FROM order_items oi\n        JOIN books b ON b.id = oi.book_id\n        WHERE oi.order_id = $1\n        ",
