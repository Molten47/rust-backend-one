{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT ci.id, ci.book_id, ci.quantity, b.price, b.bookstore_id\n        FROM cart_items ci\n        JOIN carts c ON c.id = ci.cart_id\n        JOIN books b ON b.id = ci.book_id\n        WHERE c.user_id = $1\n        AND b.bookstore_id = $2\n        AND (\n            $3::uuid[] = '{}'::uuid[]\n            OR ci.id = ANY($3)\n        )\n        ",
