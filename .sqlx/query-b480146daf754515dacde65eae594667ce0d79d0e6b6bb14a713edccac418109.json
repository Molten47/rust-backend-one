{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, title, description, location, bookstore_id,\n               starts_at, ends_at, cover_url, is_free, price, created_at\n        FROM events\n        WHERE\n            ($1::bool IS NULL OR (starts_at > now()) = $1)\n            AND ($2::bool IS NULL OR is_free = $2)\n        ORDER BY starts_at ASC\n        LIMIT $3 OFFSET $4\n        ",
